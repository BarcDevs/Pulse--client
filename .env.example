# =============================================================================
# Pulse Frontend - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# =============================================================================

# REQUIRED: Backend API server URL
# Development: http://localhost:4000
# Production: Your deployed backend URL (e.g., https://api.pulse.com)
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# REQUIRED: API version endpoint (typically v1 or v2)
NEXT_PUBLIC_SERVER_API_VERSION=v1

# REQUIRED: Frontend application hostname
# Development: http://localhost:3000
# Production: Your deployed frontend URL (e.g., https://pulse.com)
NEXT_PUBLIC_HOSTNAME=http://localhost:3000

# REQUIRED: Sentry Session Replay Sample Rate
# Value between 0.0 (0%) and 1.0 (100%)
# Development: 1.0 (capture all sessions)
# Production: 0.1 (capture 10% of sessions to reduce costs)
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=1.0

# OPTIONAL: Sentry DSN (Data Source Name) for error tracking
# Leave empty for local development without monitoring
# Get your DSN from: https://sentry.io/projects/
# Example: https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=
# -----------------------------------------------------------------------------
# Optional: Additional Configuration
# -----------------------------------------------------------------------------

# Uncomment and configure these if needed for local development

# NODE_ENV=development